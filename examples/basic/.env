# Example .env file for dotenv-fp
# Copy this to .env and modify as needed

# Database configuration
DATABASE_URL=postgresql://localhost/mydb
DATABASE_POOL_SIZE=10

# Server configuration
HOST=localhost
PORT=3000
DEBUG=true

# Security
SECRET_KEY="change-me-in-production"
API_KEY="your-api-key-here"

# Application settings
APP_NAME=MyApplication
APP_ENV=development

# Variable interpolation example
BASE_URL=https://api.example.com
API_ENDPOINT=${BASE_URL}/v1/users

# Comma-separated array
ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# Multi-line value example
WELCOME_MESSAGE="Welcome to ${APP_NAME}!
This is a multi-line message.
Enjoy your stay."

# Boolean examples (all these are truthy)
# FEATURE_ENABLED=true
# FEATURE_ENABLED=yes
# FEATURE_ENABLED=1
# FEATURE_ENABLED=on

# Export prefix (compatible with shell scripts)
export SHELL_COMPATIBLE=yes
